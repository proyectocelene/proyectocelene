    <script is:inline>
        /* =========================================
           BASE DE DATOS COMPLETA DE SERVICIOS
        ========================================= */
        let currentServiceWaMsg = "";
        let currentServiceId = "";

        let servicesInfo = {};

        // Cargar información de servicios dinámicamente
        fetch('data/servicios.json')
            .then(response => response.json())
            .then(data => {
                servicesInfo = data;
            })
            .catch(error => console.error('Error al cargar la información de servicios:', error));

        /* =========================================
           FUNCIONES DE FILTRADO Y BUSQUEDA
        ========================================= */
        function removeAccents(str) {
            return str.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        }

        function applyFilters() {
            let input = removeAccents(document.getElementById('serviceSearch').value.toLowerCase());
            let activeBtn = document.querySelector('.filter-btn.active');
            let cat = activeBtn ? activeBtn.getAttribute('onclick').match(/'([^']+)'/)[1] : 'all';

            let cards = document.querySelectorAll('.category-card');

            for (let card of cards) {
                let tags = card.getAttribute('data-cat') || "";
                let keywords = removeAccents((card.getAttribute('data-keywords') || "").toLowerCase());

                let titleEl = card.querySelector('.service-title') || card.querySelector('h2') || card.querySelector('h3');
                let title = titleEl ? removeAccents(titleEl.innerText.toLowerCase()) : "";

                let matchesSearch = input === "" || keywords.includes(input) || title.includes(input);
                let matchesCat = cat === 'all' || tags.includes(cat);

                let isBanner = (card.id === 'labPromoBanner' || card.id === 'sexualEducationalModule' || card.id === 'sexPromoBanner');

                if (isBanner) {
                    if (input === "") {
                        if (card.id === 'labPromoBanner' && cat === 'lab') card.style.display = "block";
                        else if (card.id === 'sexualEducationalModule' && cat === 'sexual') card.style.display = "block";
                        else if (card.id === 'sexPromoBanner' && cat === 'sexual') card.style.display = "block";
                        else card.style.display = "none";
                    } else {
                        card.style.display = "none";
                    }
                } else {
                    if (matchesSearch && matchesCat) {
                        card.style.display = "";
                    } else {
                        card.style.display = "none";
                    }
                }
            }
        }

        function searchServices() {
            let input = document.getElementById('serviceSearch').value;
            if (input.length > 0) {
                let btns = document.querySelectorAll('.filter-btn');
                btns.forEach(btn => btn.classList.remove('active'));
                let allBtn = Array.from(btns).find(btn => btn.getAttribute('onclick').includes(`'all'`));
                if (allBtn) allBtn.classList.add('active');
            }
            applyFilters();
        }

        function filterCategory(cat) {
            let btns = document.querySelectorAll('.filter-btn');
            btns.forEach(btn => btn.classList.remove('active'));

            let targetBtn = Array.from(btns).find(btn => btn.getAttribute('onclick').includes(`'${cat}'`));
            if (targetBtn) targetBtn.classList.add('active');

            document.getElementById('serviceSearch').value = ""; // Limpiar busqueda al cambiar categoría
            applyFilters();
        }

        /* =========================================
           FUNCIONES DEL QUIZ DE ITS
        ========================================= */
        function toggleQuiz() {
            let content = document.getElementById('quizContent');
            if (content.style.display === 'none') {
                content.style.display = 'block';
            } else {
                content.style.display = 'none';
            }
        }

        function calculateQuiz() {
            let checkboxes = document.querySelectorAll('.its-quiz:checked');
            let resultDiv = document.getElementById('quizResult');
            let score = checkboxes.length;

            let html = "";
            if (score <= 1) {
                html = "<strong>0–1 puntos → BAJO RIESGO:</strong><br> Vas bien, pero no te confíes. Sigue protegiéndote con condón. ¡Prevenir es amarte!";
                resultDiv.style.borderLeftColor = "#25d366";
                resultDiv.style.background = "#e8f5e9";
            } else if (score <= 4) {
                html = "<strong>2–4 puntos → RIESGO MODERADO:</strong><br> Más vale checar que lamentar. Te invitamos con total confianza a agendar nuestro <strong>Paquete Básico o Pareja</strong>. ¡Cuidamos de ti sin juzgarte!";
                resultDiv.style.borderLeftColor = "#f0ad4e";
                resultDiv.style.background = "#fff3e0";
            } else {
                html = "<strong>5 o más puntos → RIESGO ALTO:</strong><br> Necesitas una prueba... ¡y pronto! Agenda nuestro <strong>Paquete Completo Tranquilo</strong> hoy mismo. Deja de vivir con la duda, estamos aquí para apoyarte y guiarte con amor y absoluta discreción.";
                resultDiv.style.borderLeftColor = "#d81b60";
                resultDiv.style.background = "#fce4ec";
            }

            resultDiv.innerHTML = html;
            resultDiv.style.display = "block";
        }

        /* =========================================
           FUNCIONES DEL MODAL
        ========================================= */
        function copyToClipboard(inputId, btn) {
            var copyText = document.getElementById(inputId);
            copyText.select();
            copyText.setSelectionRange(0, 99999);
            navigator.clipboard.writeText(copyText.value).then(() => {
                let originalHTML = btn.innerHTML;
                btn.innerHTML = "¡Copiado! ✅";
                btn.style.background = "var(--pc-rosa-fuerte)";
                setTimeout(() => {
                    btn.innerHTML = originalHTML;
                    btn.style.background = "";
                }, 2000);
            });
        }

