                            <p style="font-size: 0.95rem;"><strong>1.</strong> Envíanos un mensaje por WhatsApp para agendar tu cita y menciona que pagarás en efectivo en el consultorio.</p>
                        </div>

                        <div id="instructionsTransferencia_${id}" style="display: none; margin-top: 15px; padding-top: 10px; border-top: 2px dashed #ccc;">
                            <p style="font-size: 0.95rem; font-weight:bold; margin-bottom: 10px; color: var(--pc-rosa-fuerte);">Total a transferir: $${precioOriginal.toFixed(2)} MN</p>
                            <div class="copy-box-modern"><span class="label">CLABE</span><input type="text" id="clabe_${id}" value="722969010854962949" readonly><button type="button" onclick="copyToClipboard('clabe_${id}', this)"><span>📋</span> Copiar</button></div>
                            <div class="copy-box-modern"><span class="label">Beneficiario</span><input type="text" id="benef_${id}" value="Carlos Donato Dueñas Prieto" readonly><button type="button" onclick="copyToClipboard('benef_${id}', this)"><span>📋</span> Copiar</button></div>
                            <div class="copy-box-modern"><span class="label">Banco</span><input type="text" id="banco_${id}" value="Mercado Pago W" readonly><button type="button" onclick="copyToClipboard('banco_${id}', this)"><span>📋</span> Copiar</button></div>
                            <ul class="step-list" style="margin-top: 10px;"><li>Realiza la transferencia (guarda tu comprobante).</li><li>Envíanos un mensaje por WhatsApp con tu comprobante para confirmar tu cita.</li></ul>
                        </div>

                        <div id="instructionsMercadoPago_${id}" style="display: none; margin-top: 15px; padding-top: 10px; border-top: 2px dashed #ccc;">
                            <p style="font-size: 0.95rem; font-weight:bold; margin-bottom: 10px; color: var(--pc-rosa-fuerte);">Total a pagar en línea: $${precioOnline.toFixed(2)} MN</p>
                            ${!info.mpLink ? `<div class="copy-box-modern"><span class="label">Total $</span><input type="text" id="mpTotal_${id}" value="${precioOnline.toFixed(2).replace('.', ',')}" readonly><button type="button" onclick="copyToClipboard('mpTotal_${id}', this)"><span>📋</span> Copiar</button></div><p style="color: #e65100; font-size: 0.85rem; font-weight: 800; margin-bottom: 10px;">⚠️ Copia la cantidad exacta con decimales antes de ir al enlace.</p>` : ''}
                            <a href="${mpLink}" target="_blank" class="btn-wa" style="display: block; text-align: center; border-radius: 10px; padding: 10px; font-size: 1rem; width: 100%; border-color: var(--pc-negro); box-shadow: 3px 3px 0 var(--pc-negro);">Pagar en Mercado Pago ➔</a>
                            <ul class="step-list" style="margin-top: 15px;"><li>Realiza el pago en el enlace (guarda captura de pantalla).</li><li>Envíanos tu comprobante por WhatsApp para confirmar tu cita.</li></ul>
                        </div>
                    </div>
                `;
            }

            // Agregar botón de guía educativa si el servicio lo tiene configurado
            if (info.eduLink) {
                bodyHtml += `<div style="text-align: center; margin-top: 20px;"><a href="${info.eduLink}" class="btn" style="background: var(--pc-azul-suave); border-color: var(--pc-negro); width: 100%; box-shadow: 0 4px 0 var(--pc-negro); display: block;"><span>📖</span> Leer Guía Educativa</a>`;
            }

            if (id === 'papa') {
                document.getElementById('papa_extra_fields').style.display = 'block';
            } else {
                document.getElementById('papa_extra_fields').style.display = 'none';
            }

            if (id.startsWith('podo_')) {
                document.getElementById('btn_domicilio').style.display = 'block';
            } else {
                document.getElementById('btn_domicilio').style.display = 'none';
            }

            document.getElementById('modalBody').innerHTML = bodyHtml;
            currentServiceWaMsg = info.waMsg;
            currentServiceId = id;

            document.getElementById('serviceModal').style.display = "flex";
        }

        function closeModal() { document.getElementById('serviceModal').style.display = "none"; }

        function sendServiceWa(isDomicilio = false) {
            let nombre = document.getElementById('sm_nombre').value.trim() || "No especificado";
            let edad = document.getElementById('sm_edad').value.trim() || "-";
            let duda = document.getElementById('sm_duda').value.trim();
            let msg = isDomicilio ? `Hola Podóloga Sara 🦶.\nSoy *${nombre}* (${edad} años).\nMe interesa el servicio: *${currentServiceWaMsg}*.` : `Hola Proyecto Celene 🌸.\nSoy *${nombre}* (${edad} años).\nMe interesa agendar/información sobre: *${currentServiceWaMsg}*.`;

            if (currentServiceWaMsg === 'Papanicolaou') {
                let mtv = document.getElementById('sm_papa_motivo').value.trim() || "No especificó";
                let menst = document.getElementById('sm_papa_menstrua').value || "No especificó";
                let sinto = document.getElementById('sm_papa_sintomas').value.trim() || "No especificó";
                let fecha = document.getElementById('sm_papa_fecha').value || "No recuerda";

                msg += `\n\n*Datos Clínicos Papanicolaou:*\n- Motivo: ${mtv}\n- Menstrua: ${menst}\n- Síntomas Menopausia: ${sinto}\n- Último estudio: ${fecha}`;
            }

            if (duda) {
                msg += `\n\nMi comentario/duda es: "${duda}"`;
            }

            let paymentMethodElement = document.querySelector(`input[name="paymentMethod_${currentServiceId}"]:checked`);
            if (paymentMethodElement) {
                let paymentText = "";
                if (paymentMethodElement.value === 'efectivo') paymentText = "Efectivo en Consultorio";
                if (paymentMethodElement.value === 'transferencia') paymentText = "Transferencia Bancaria";
                if (paymentMethodElement.value === 'mercadopago') paymentText = "Pago en Línea (Mercado Pago)";
                msg += `\n\n*Método de Pago seleccionado:* ${paymentText}`;
            }

            if (isDomicilio) {
                msg += `\n\n*Modalidad:* Atención a Domicilio 🏡`;
                window.open(`https://wa.me/525521300344?text=${encodeURIComponent(msg)}`, '_blank');
            } else {
                if (currentServiceId.startsWith('podo_')) msg += `\n\n*Modalidad:* En Clínica Celene 🏥`;
                window.open(`https://wa.me/526611044050?text=${encodeURIComponent(msg)}`, '_blank');
            }
            
            closeModal();
        }
        window.onclick = function (event) { if (event.target == document.getElementById('serviceModal')) closeModal(); }

        // Iniciar con la vista de "Todos" activa y sin banners basura
        filterCategory('all');
    </script>

    
</Layout>
