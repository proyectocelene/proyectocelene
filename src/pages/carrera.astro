        <!-- ================= DATOS LOGÍSTICOS ================= -->
        <section class="logistics-grid">
            <div class="logistic-card">
                <span class="card-icon">🏷️</span>
                <h3>Costo Inscripción</h3>
                <p>$200.00 MN</p>
                <div class="sub-detail">Cuota de recuperación única</div>
            </div>
            <div class="logistic-card">
                <span class="card-icon">📅</span>
                <h3>Fecha del Evento</h3>
                <p>17 Oct 2026</p>
                <div class="sub-detail">¡Reserva el sábado en tu agenda!</div>
            </div>
            <div class="logistic-card">
                <span class="card-icon">⏰</span>
                <h3>Horarios Clave</h3>
                <p>6:00 AM Registro</p>
                <div class="sub-detail">Salida puntual 7:00 AM</div>
            </div>
            <div class="logistic-card">
                <span class="card-icon">📍</span>
                <h3>Punto de Partida</h3>
                <p>Pabellón Rosarito</p>
                <a href="https://maps.app.goo.gl/do65rxA2ud2Nx3jM8" target="_blank" class="btn-map">Ver mapa 🗺️</a>
            </div>
            <div class="logistic-card">
                <span class="card-icon">🚑</span>
                <h3>Servicios en Ruta</h3>
                <p>Seguridad Total</p>
                <div class="sub-detail">Puntos de hidratación, Baños (Pabellón), Cruz Roja, Bomberos y Policía.</div>
            </div>
            <div class="logistic-card">
                <span class="card-icon">🏆</span>
                <h3>Premiación</h3>
                <p>Categoría Única</p>
                <div class="sub-detail">Reconocimientos a los primeros lugares absolutos. Evento 100% recaudatorio.</div>
            </div>
        </section>

        <!-- ================= SECCIÓN RUTAS INTERACTIVAS ================= -->
        <section class="routes-section" id="rutas-carrera">
            <div class="section-header">
                <h2 class="section-title">Modalidades y Rutas</h2>
            </div>
            <p style="text-align: center; margin-top: -15px; margin-bottom: 30px; font-weight: bold; color: #555;">
                Haz clic en una modalidad para visualizar su trayecto y puntos de referencia:
            </p>

            <div class="routes-tabs">
                <button class="tab-btn active" onclick="switchRoute('caminata')">Modalidad Caminata (Recreativa)</button>
                <button class="tab-btn" onclick="switchRoute('carrera')">Modalidad Carrera (Competitiva)</button>
            </div>

            <!-- RUTA CAMINATA -->
            <div class="route-content active" id="route_caminata">
                <div class="route-info">
                    <h4>Caminata Recreativa</h4>
                    <p>Diseñada para toda la familia. Puedes caminar, trotar o correr a tu propio ritmo con el corazón.</p>
                    <ul class="route-steps">
                        <li><strong>Inicio:</strong> Salida general en el estacionamiento de Pabellón Rosarito.</li>
                        <li><strong>Trayecto:</strong> Avanzamos sobre la ruta principal con dirección norte hacia MacDonald.</li>
                        <li><strong>Retorno:</strong> Vuelta U en MacDonald y reincorporación a la vía contraria.</li>
                        <li><strong>Meta:</strong> Llegada de regreso en el punto de encuentro en Pabellón Rosarito.</li>
                    </ul>
                </div>
                <div>
                    <!-- SVG Animado para Caminata -->
                    <svg viewBox="0 0 500 200" class="route-map-svg" style="--path-d: 'M 50 100 C 150 40, 350 40, 450 100 C 350 160, 150 160, 50 100';">
                        <!-- Línea de Trayecto -->
                        <path id="path_caminata" d="M 50 100 C 150 40, 350 40, 450 100 C 350 160, 150 160, 50 100" fill="none" stroke="#ff4081" stroke-width="4" stroke-linecap="round" stroke-dasharray="8 6" />
                        
                        <!-- Pines / Puntos Clave -->
                        <circle cx="50" cy="100" r="10" fill="#333" stroke="#fff" stroke-width="2" />
                        <text x="35" y="130" font-size="11" font-weight="900" fill="#333">🏁 Pabellón</text>

                        <circle cx="450" cy="100" r="8" fill="#ffd23f" stroke="#333" stroke-width="2" />
                        <text x="400" y="130" font-size="11" font-weight="900" fill="#333">🍔 MacDonald</text>
                        
                        <!-- Corredora Animada -->
                        <g class="animated-runner" style="offset-path: path('M 50 100 C 150 40, 350 40, 450 100 C 350 160, 150 160, 50 100');">
                            <text x="-15" y="10" font-size="24">🏃‍♀️</text>
                        </g>
                    </svg>
                </div>
            </div>

            <!-- RUTA CARRERA -->
            <div class="route-content" id="route_carrera">
                <div class="route-info">
                    <h4>Carrera de Velocidad</h4>
                    <p>Para corredores experimentados que desean medir su resistencia física apoyando una causa noble.</p>
                    <ul class="route-steps">
                        <li><strong>Inicio:</strong> Salida a toda velocidad desde el arco en Pabellón Rosarito.</li>
                        <li><strong>Trayecto:</strong> Recorrido extendido con dirección sur hacia Campos Emiliano.</li>
                        <li><strong>Retorno:</strong> Punto de hidratación y retorno U en Campos Emiliano.</li>
                        <li><strong>Meta:</strong> Esprint final de regreso en Pabellón Rosarito para recibir medalla.</li>
                    </ul>
                </div>
                <div>
                    <!-- SVG Animado para Carrera -->
                    <svg viewBox="0 0 500 200" class="route-map-svg" style="--path-d: 'M 50 100 C 150 20, 350 20, 450 100 C 350 180, 150 180, 50 100';">
                        <!-- Línea de Trayecto -->
                        <path id="path_carrera" d="M 50 100 C 150 20, 350 20, 450 100 C 350 180, 150 180, 50 100" fill="none" stroke="#25d366" stroke-width="4" stroke-linecap="round" stroke-dasharray="10 5" />
                        
                        <!-- Pines / Puntos Clave -->
                        <circle cx="50" cy="100" r="10" fill="#333" stroke="#fff" stroke-width="2" />
                        <text x="35" y="130" font-size="11" font-weight="900" fill="#333">🏁 Pabellón</text>

                        <circle cx="450" cy="100" r="8" fill="#d81b60" stroke="#fff" stroke-width="2" />
                        <text x="375" y="130" font-size="11" font-weight="900" fill="#333">⚽ Campos Emiliano</text>

                        <!-- Corredora Animada -->
                        <g class="animated-runner" style="offset-path: path('M 50 100 C 150 20, 350 20, 450 100 C 350 180, 150 180, 50 100'); animation-duration: 4.5s;">
                            <text x="-15" y="10" font-size="24">🏃‍♀️</text>
                        </g>
                    </svg>
                </div>
            </div>
        </section>

        <!-- ================= AMENIDADES & KIT ================= -->
        <section class="section-header">
            <h2 class="section-title">¿Qué Incluye tu Registro?</h2>
        </section>

        <section class="kit-grid">
            <!-- CAMISETA -->
            <div class="kit-card">
                <span class="kit-badge" style="background: var(--carrera-neon-green);">A LA VENTA</span>
                <h4>Camiseta Con Causa</h4>
                <p style="margin-bottom: 10px;">¡Vístete de rosa! La camiseta <strong>no está incluida</strong> en el boleto base. Apóyanos comprándola para recaudar fondos para mastografías.</p>
                <div style="background: var(--carrera-rosa-pastell); border: 2px dashed var(--carrera-rosa-fuerte); padding: 5px 15px; border-radius: 10px; font-weight: 900; color: var(--carrera-rosa-fuerte); font-size: 1.2rem; margin-bottom: 20px;">Costo: $250.00 MN</div>
                
                <div style="min-height: 250px; display: flex; align-items: center; justify-content: center;">
                    <div id="interactive-shirt-img" style="transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); transform-origin: center center;">
                        <img src="https://i.ibb.co/k2QNRD7S/CAMISA13.png" alt="Camiseta 13va Carrera Celene" class="kit-shirt-img">
                    </div>
                </div>
                
                <p style="font-size: 0.85rem; font-weight: bold; margin-bottom: 5px; color: var(--carrera-negro);">Toca para ver el tamaño:</p>
                <div class="shirt-sizes">
                    <button class="size-btn" onclick="selectShirtSize('CH', this)">CH</button>
                    <button class="size-btn active" onclick="selectShirtSize('M', this)">M</button>
                    <button class="size-btn" onclick="selectShirtSize('G', this)">G</button>
                    <button class="size-btn" onclick="selectShirtSize('XL', this)">XL</button>
                </div>
                <p style="font-size: 0.85rem; font-weight: bold; margin-top: 5px; color: #666;">*Podrás agregarla fácilmente a tu total desde el formulario de registro de abajo.</p>
            </div>

            <!-- MEDALLA -->
            <div class="kit-card">
                <span class="kit-badge">A LA META</span>
                <h4>Medalla Conmemorativa</h4>
                <p>Al cruzar la meta, se te entregará tu hermosa medalla metálica conmemorativa de la 13va. Gran Carrera incluida con tu boleto.</p>
                
                <div class="medal-mockup">
                    <div class="medal-ribbon"></div>
                    <div class="medal-gold">🏅</div>
                </div>

                <p style="font-weight: 800; color: var(--carrera-rosa-fuerte); margin-top: 15px;">
                    ¡El trofeo de tu esfuerzo por una causa!
                </p>
            </div>
        </section>

        <!-- ================= SECCIÓN VOLUNTARIOS ================= -->
        <section class="motivation-container" style="background: var(--carrera-amarillo);">
            <h3 style="color: var(--carrera-negro); text-shadow: 2px 2px 0 var(--carrera-blanco); font-size: 2.2rem;">¿No quieres correr pero quieres ayudar?</h3>
            <p>Una carrera con causa necesita de muchas manos y corazones. Únete al <strong>Staff Voluntario</strong> para repartir medallas, dar agua en la ruta o ayudar con la logística vehicular.</p>
            <a href="https://wa.me/526611044050?text=Hola,%20me%20gustar%C3%ADa%20unirme%20como%20voluntario%20para%20el%20Staff%20de%20la%20carrera." target="_blank" class="btn-love" style="background: var(--carrera-negro); color: white;">¡Quiero ser Voluntario! 🙋‍♀️🙋‍♂️</a>
        </section>

        <!-- ================= SECCIÓN MOTIVACIONAL ================= -->
        <section class="motivation-container">
            <h3>Cada paso cuenta, cada paso ayuda.</h3>
            <p>Juntos hacemos la diferencia. Corremos con el corazón por amor a ellas, porque nunca están solas.</p>
            <button class="btn-love" onclick="throwHearts()">¡Enviar Amor y Apoyo! 💖</button>
        </section>

        <!-- ================= FORMULARIO E INSCRIPCIÓN ================= -->
        <section class="registration-section" id="registro-carrera">
            <div class="form-header">
                <h3>Formulario de Inscripción</h3>
                <p>Registra tus datos de corredor y obtén tus accesos por WhatsApp de inmediato.</p>
            </div>

            <!-- Selección de cantidad de participantes -->
            <div class="form-group" style="max-width: 400px; margin: 0 auto 30px;">
                <label for="num_participants" style="text-align: center;">¿A cuántas personas vas a inscribir?</label>
                <select id="num_participants" class="form-select" onchange="renderParticipantForms()">
                    <option value="1">1 Participante ($200 MN)</option>
                    <option value="2">2 Participantes ($400 MN)</option>
                    <option value="3">3 Participantes ($600 MN)</option>
                    <option value="4">4 Participantes ($800 MN)</option>
                    <option value="5">5 Participantes ($1000 MN)</option>
                </select>
            </div>

            <form id="raceRegistrationForm" onsubmit="event.preventDefault(); processRegistration();">
                <!-- Contenedor dinámico de formularios -->
                <div id="participants_container"></div>

                <!-- EXENCIÓN Y CERTIFICADO MÉDICO -->
                <div class="waiver-box">
                    <label class="waiver-label">
                        <input type="checkbox" id="waiver_check" required>
                        <span><strong>Exención de Responsabilidad Médica:</strong> Declaro que me encuentro en excelente estado de salud física para participar en este evento deportivo y eximo a Proyecto Celene A.C. de cualquier responsabilidad por lesión o accidente durante la carrera.</span>
                    </label>
                    <div style="background: var(--carrera-neon-green); color: var(--carrera-negro); padding: 15px; border-radius: 12px; border: 3px solid var(--carrera-negro); margin-top: 20px; font-weight: 800; font-size: 0.95rem; display: flex; align-items: center; gap: 15px; box-shadow: 4px 4px 0 var(--carrera-negro);">
                        <span style="font-size: 2.5rem;">🎁</span> 
                        <span><strong>¡Gran Beneficio!</strong> Tu compra de boleto incluye un <strong>Certificado Médico Gratuito</strong>. Acude a nuestra clínica comunitaria en los días previos a la carrera para realizártelo sin costo.</span>
                    </div>
                </div>

                <!-- Selección del método de pago -->
                <div class="form-group">
                    <label style="text-align: center; display: block; font-size: 1.15rem; margin-bottom: 15px;">
                        Selecciona tu Método de Pago Preferido:
                    </label>
                    <div class="payment-methods">
                        <div class="payment-option active" onclick="selectPaymentMethod('efectivo', this)">
                            <input type="radio" name="pay_method" value="efectivo" checked>
                            <span class="payment-icon">💵</span>
                            <span>Efectivo</span>
                        </div>
                        <div class="payment-option" onclick="selectPaymentMethod('mercadopago', this)">
                            <input type="radio" name="pay_method" value="mercadopago">
                            <span class="payment-icon">💳</span>
                            <span>Pago en Línea</span>
                        </div>
                        <div class="payment-option" onclick="selectPaymentMethod('transferencia', this)">
                            <input type="radio" name="pay_method" value="transferencia">
                            <span class="payment-icon">🏦</span>
                            <span>Transferencia</span>
                        </div>
                    </div>
                </div>

                <!-- DETALLES EFECTIVO -->
                <div class="payment-instructions" id="inst_efectivo" style="display: block;">
                    <h5 style="font-size: 1.1rem; color: var(--carrera-rosa-fuerte); margin-bottom: 10px;">💵 Pago en Efectivo</h5>
                    <p style="font-size: 0.95rem; font-weight: bold; color: #444;">
                        Puedes acudir a realizar tu pago directo en nuestro consultorio comunitario de Proyecto Celene Rosarito en un horario de lunes a sábado de 9:00 AM a 4:00 PM.
                    </p>
                </div>

                <!-- DETALLES MERCADO PAGO -->
                <div class="payment-instructions" id="inst_mercadopago" style="display: none;">
                    <h5 style="font-size: 1.1rem; color: var(--carrera-rosa-fuerte); margin-bottom: 10px;">💳 Pago en Línea (Mercado Pago)</h5>
                    <div style="background: var(--carrera-amarillo); padding: 15px; border-radius: 12px; border: 2px dashed var(--carrera-negro); margin-bottom: 20px; text-align: center; box-shadow: 4px 4px 0 var(--carrera-rosa-pastell);">
                        <p style="font-size: 1rem; font-weight: 800; margin-bottom: 10px; color: var(--carrera-negro);">Tu Total a Pagar en Línea (comisión incluida):</p>
                        <div style="display: flex; flex-wrap: nowrap; align-items: stretch; background: white; border: 2px solid var(--carrera-negro); border-radius: 12px; overflow: hidden; margin: 0 auto; width: 100%;">
                            <span style="background: var(--carrera-gray); padding: 8px 12px; font-weight: 900; border-right: 2px solid var(--carrera-negro); display: flex; align-items: center; white-space: nowrap; font-size: 0.9rem; color: #333;">Total $</span>
                            <input type="text" id="mercadoPagoTotalInput" value="0.00" readonly style="flex: 1; min-width: 0; border: none; padding: 8px 12px; font-size: 1.1rem; font-weight: bold; font-family: 'Courier Prime', monospace; outline: none; background: transparent; text-align: center; color: var(--carrera-rosa-fuerte);">
                            <button type="button" onclick="copyText('mercadoPagoTotalInput', this)" class="btn-copy" style="border: none; border-left: 2px solid var(--carrera-negro); border-radius: 0; padding: 8px 15px; font-weight: 900; background: var(--carrera-negro); color: white; cursor: pointer;">Copiar</button>
                        </div>
                        <p style="color: var(--carrera-rosa-fuerte); font-size: 0.8rem; margin-top: 10px; font-weight: 900; text-transform: uppercase;">⚠️ ¡Ojo! Asegúrate de poner la cantidad exacta con decimales en Mercado Pago.</p>
                    </div>
                    <p style="font-size: 0.95rem; font-weight: bold; color: #444; margin-bottom: 10px;">
                        1. Copia el total de arriba con la comisión ya de procesamiento incluida.<br>
                        2. Presiona el siguiente botón para abrir la terminal de pago de Mercado Pago y digita el total:<br>
                        <a href="https://link.mercadopago.com.mx/drdonato" target="_blank" rel="noopener" class="btn-sports-secondary" style="display: inline-flex; width: 100%; max-width: 100%; box-shadow: 3px 3px 0 var(--carrera-negro); margin: 10px 0; font-size: 1rem; padding: 10px 20px; text-decoration: none;">Pagar en Mercado Pago ➔</a><br>
                        3. Toma captura de pantalla de tu comprobante y envíala al confirmar tu registro por WhatsApp abajo.
                    </p>
                </div>

                <!-- DETALLES DE BANCO (TRANSFERENCIA) -->
                <div class="payment-instructions" id="inst_transferencia" style="display: none;">
                    <h5 style="font-size: 1.1rem; color: var(--carrera-rosa-fuerte); margin-bottom: 10px;">🏦 Datos Bancarios para Transferencia</h5>
                    <p style="font-size: 0.95rem; font-weight: bold; margin-bottom: 12px; color: #444;">
                        Realiza tu transferencia por el total y conserva el comprobante para enviarlo por WhatsApp.
                    </p>
                    <div class="bank-details-box">
                        <div class="bank-detail-item">
                            <span>Beneficiario:</span>
                            <span class="detail-value" id="val_beneficiario">Francisco Sandoval Deras</span>
                            <button type="button" class="btn-copy" onclick="copyText('val_beneficiario', this)">Copiar</button>
                        </div>
                        <div style="font-size: 0.85rem; color: #555; margin-bottom: 12px; font-weight: bold; text-align: left; padding-left: 5px;">
                            👤 <em>Nota: El Sr. Francisco es el Fundador y Director General de la A.C. (<a href="quienes-somos.html#director" target="_blank" style="color: var(--carrera-rosa-fuerte); text-decoration: underline;">Ver su perfil en la fundación ➔</a>)</em>
                        </div>
                        <div class="bank-detail-item">
                            <span>Banco:</span>
                            <span class="detail-value" id="val_banco">Santander</span>
                            <button type="button" class="btn-copy" onclick="copyText('val_banco', this)">Copiar</button>
                        </div>
                        <div class="bank-detail-item">
                            <span>Tarjeta / Cuenta:</span>
                            <span class="detail-value" id="val_clabe">5579070150175472</span>
                            <button type="button" class="btn-copy" onclick="copyText('val_clabe', this)">Copiar</button>
                        </div>
                        <div class="bank-detail-item">
                            <span>Concepto:</span>
                            <span class="detail-value" id="val_concepto">Carrera Celene</span>
                            <button type="button" class="btn-copy" onclick="copyText('val_concepto', this)">Copiar</button>
                        </div>
                    </div>
                </div>

                <!-- CAJA DE TOTAL DINÁMICA -->
                <div class="total-box">
                    <h4>Total a Pagar</h4>
                    <div class="total-amount" id="totalPriceDisplay">$200.00 MN</div>
                    <div class="total-commission" id="commissionDisplay" style="display: none;"></div>
                </div>

                <div style="text-align: center;">
                    <button type="submit" class="btn-sports-primary btn-heartbeat" style="width: 100%; max-width: 450px;">
                        Completar Registro por WhatsApp 🚀
                    </button>
                </div>
            </form>
        </section>

        <!-- ================= SECCIÓN PATROCINADORES ================= -->
        <section class="section-header">
            <h2 class="section-title">Nuestros Patrocinadores y Aliados</h2>
        </section>

        <section class="sponsors-grid">
            <div class="sponsor-box">
                <div class="sponsor-logo-placeholder">🏛️</div>
                <h4>Gobierno del Estado de Baja California</h4>
                <p>Aliado Institucional</p>
            </div>
            <div class="sponsor-box">
                <div class="sponsor-logo-placeholder">🏢</div>
                <h4>Pabellón Rosarito</h4>
                <p>Sede Oficial de Salida y Meta</p>
            </div>
            <div class="sponsor-box">
                <div class="sponsor-logo-placeholder">🕊️</div>
                <h4>Grupo Funerario Santana</h4>
                <p>Patrocinador Oficial con Causa</p>
            </div>
            <div class="sponsor-box" style="background: var(--carrera-amarillo); border-color: var(--carrera-rosa-fuerte);">
                <div class="sponsor-logo-placeholder">🤝</div>
                <h4 style="color: var(--carrera-rosa-fuerte); font-size: 1.15rem;">¿Quieres ser Patrocinador?</h4>
                <p style="color: var(--carrera-negro);">Únete a la Alianza Rosa Empresarial (ESR).</p>
                <a href="patrocinadores.html" class="btn-map" style="margin-top: 15px; background: var(--carrera-rosa-fuerte); color: white; padding: 8px 15px; font-size: 0.95rem; box-shadow: 3px 3px 0 var(--carrera-negro);">Ver Beneficios ➔</a>
            </div>
        </section>

        <!-- ================= FOOTER ================= -->
        <footer class="main-footer">
            <h2 class="footer-brand">Proyecto Celene A.C.</h2>
            <p class="footer-text">Tu lucha es mi lucha. Juntos apoyando la detección oportuna y el tratamiento contra el cáncer de mama, brindando esperanza y acompañamiento a quien más lo necesita.</p>
            
            <div class="footer-links">
                <a href="tel:6611044050">📞 661-104-4050</a>
                <a href="mailto:contacto@proyectocelene.org">✉️ contacto@proyectocelene.org</a>
            </div>

            <p style="font-size: 0.85rem; color: rgba(255,255,255,0.7); margin-top: 20px; font-weight: bold;">© 2026 Proyecto Celene Rosarito. Todos los derechos reservados.</p>
        </footer>

