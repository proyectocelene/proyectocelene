    <!-- SCRIPTS DE INTERACTIVIDAD -->
    <script is:inline>
        // --- 1. LÓGICA DEL CONTADOR REGRESIVO ---
        function updateCountdown() {
            // Fecha del evento: 17 de Octubre, 2026 07:00:00
            const eventDate = new Date("October 17, 2026 07:00:00").getTime();
            const now = new Date().getTime();
            const difference = eventDate - now;

            if (difference < 0) {
                document.getElementById("cd_days").innerText = "00";
                document.getElementById("cd_hours").innerText = "00";
                document.getElementById("cd_mins").innerText = "00";
                document.getElementById("cd_secs").innerText = "00";
                return;
            }

            const days = Math.floor(difference / (1000 * 60 * 60 * 24));
            const hours = Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((difference % (1000 * 60)) / 1000);

            document.getElementById("cd_days").innerText = days < 10 ? "0" + days : days;
            document.getElementById("cd_hours").innerText = hours < 10 ? "0" + hours : hours;
            document.getElementById("cd_mins").innerText = minutes < 10 ? "0" + minutes : minutes;
            document.getElementById("cd_secs").innerText = seconds < 10 ? "0" + seconds : seconds;
        }
        setInterval(updateCountdown, 1000);
        updateCountdown();

        // --- 2. SELECTOR DE TALLA INTERACTIVO Y CAMISA JS ---
        function selectShirtSize(size, btn) {
            document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            const img = document.getElementById('interactive-shirt-img');
            if (size === 'CH') img.style.transform = 'scale(0.85)';
            if (size === 'M') img.style.transform = 'scale(1)';
            if (size === 'G') img.style.transform = 'scale(1.15)';
            if (size === 'XL') img.style.transform = 'scale(1.3)';
        }

        function toggleShirtSize(index) {
            const check = document.getElementById(`part_shirt_check_${index}`);
            const box = document.getElementById(`part_shirt_size_box_${index}`);
            if (check.checked) {
                box.style.display = 'block';
            } else {
                box.style.display = 'none';
            }
        }

        // --- 3. SELECTOR DE RUTA INTERACTIVO ---
        function switchRoute(route) {
            const tabs = document.querySelectorAll('.tab-btn');
            tabs.forEach(tab => {
                if (tab.getAttribute('onclick').includes(route)) {
                    tab.classList.add('active');
                } else {
                    tab.classList.remove('active');
                }
            });

            const contents = document.querySelectorAll('.route-content');
            contents.forEach(content => {
                content.classList.remove('active');
            });

            document.getElementById('route_' + route).classList.add('active');
        }

        // --- 4. GENERADOR DE CORAZONES FLOTANTES (CONFETTI) ---
        function throwHearts() {
            const heartIcons = ['💖', '🌸', '👟', '💕', '💗', '🎗️', '🎀'];
            const colors = ['#ff2a85', '#ff4081', '#d81b60', '#fce4ec', '#ffd23f'];

            for (let i = 0; i < 20; i++) {
                setTimeout(() => {
                    const heart = document.createElement('div');
                    heart.className = 'heart-particle';
                    heart.innerText = heartIcons[Math.floor(Math.random() * heartIcons.length)];
                    
                    const leftOffset = Math.random() * 100; // Porcentaje de pantalla
                    const scale = 0.5 + Math.random() * 0.8;
                    const duration = 2.5 + Math.random() * 1.5;
                    const moveX = (Math.random() * 200 - 100) + 'px'; // Desviación en el eje X

                    heart.style.left = leftOffset + 'vw';
                    heart.style.animationDuration = duration + 's';
                    heart.style.setProperty('--move-x', moveX);
                    heart.style.transform = `scale(${scale})`;
                    heart.style.color = colors[Math.floor(Math.random() * colors.length)];

                    document.body.appendChild(heart);

                    // Eliminar la partícula después de la animación
                    setTimeout(() => {
                        heart.remove();
                    }, duration * 1000);
                }, i * 100);
            }
        }

        // --- 5. LÓGICA DINÁMICA DEL FORMULARIO DE REGISTRO ---
        function renderParticipantForms() {
            const count = parseInt(document.getElementById('num_participants').value);
            const container = document.getElementById('participants_container');
            container.innerHTML = '';

            for (let i = 1; i <= count; i++) {
                const card = document.createElement('div');
                card.className = 'participant-card';
                card.innerHTML = `
                    <div class="participant-title">
                        <span>🏃‍♀️ Participante #${i}</span>
                        <span style="font-size: 0.9rem; color: #777;">Datos obligatorios</span>
                    </div>
                    <div class="participant-grid">
                        <div class="form-group">
                            <label for="part_name_${i}">Nombre Completo:</label>
                            <input type="text" id="part_name_${i}" class="form-input" placeholder="Nombre y Apellido" required>
                        </div>
                        <div class="form-group">
                            <label for="part_age_${i}">Edad:</label>
                            <input type="number" id="part_age_${i}" class="form-input" placeholder="Ej. 34" min="3" max="99" required>
                        </div>
                        <div class="form-group">
                            <label for="part_phone_${i}">Teléfono:</label>
                            <input type="tel" id="part_phone_${i}" class="form-input" placeholder="Ej. 661 123 4567" required>
                        </div>
                        <div class="form-group">
                            <label for="part_modality_${i}">Modalidad:</label>
                            <select id="part_modality_${i}" class="form-select">
                                <option value="Caminata 5K">Caminata 5K (Recreativa)</option>
                                <option value="Carrera 10K">Carrera 10K (Competitiva)</option>
                            </select>
                        </div>
                        
                        <!-- SECCIÓN COMPRA DE CAMISA -->
                        <div class="form-group shirt-addon-box">
                            <label style="color: var(--carrera-rosa-fuerte); display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 1rem;">
                                <input type="checkbox" id="part_shirt_check_${i}" onchange="toggleShirtSize(${i}); calculateCost();" style="transform: scale(1.5); accent-color: var(--carrera-rosa-fuerte);">
                                💖 Apoyar comprando Camiseta Oficial (+$250 MN)
                            </label>
                            <div id="part_shirt_size_box_${i}" style="display: none; margin-top: 15px;">
                                <label for="part_shirt_size_${i}">Elige tu Talla:</label>
                                <select id="part_shirt_size_${i}" class="form-select">
                                    <option value="Chica (CH)">Chica (CH)</option>
                                    <option value="Mediana (M)">Mediana (M)</option>
                                    <option value="Grande (G)">Grande (G)</option>
                                    <option value="Extra Grande (XL)">Extra Grande (XL)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            }
            calculateCost();
        }

        // --- 6. LÓGICA DE METODOS DE PAGO Y COSTOS ---
        let currentPaymentMethod = 'efectivo';

        function selectPaymentMethod(method, element) {
            currentPaymentMethod = method;
            
            // Actualizar clases activas visuales
            const options = document.querySelectorAll('.payment-option');
            options.forEach(opt => opt.classList.remove('active'));
            element.classList.add('active');

            // Actualizar botones de opción ocultos
            element.querySelector('input[type="radio"]').checked = true;

            // Mostrar/Ocultar bloques de instrucciones condicionalmente
            document.getElementById('inst_transferencia').style.display = method === 'transferencia' ? 'block' : 'none';
            document.getElementById('inst_mercadopago').style.display = method === 'mercadopago' ? 'block' : 'none';
            document.getElementById('inst_efectivo').style.display = method === 'efectivo' ? 'block' : 'none';

            calculateCost();
        }

        function calculateCost() {
            const count = parseInt(document.getElementById('num_participants').value);
            let subtotal = count * 200;
            
            // Sumar camisas seleccionadas ($250 por cada una)
            for (let i = 1; i <= count; i++) {
                const check = document.getElementById(`part_shirt_check_${i}`);
                if (check && check.checked) {
                    subtotal += 250;
                }
            }

            let total = subtotal;

            const commDisplay = document.getElementById('commissionDisplay');
            const priceDisplay = document.getElementById('totalPriceDisplay');

            if (currentPaymentMethod === 'mercadopago' && subtotal > 0) {
                // FÓRMULA DE COMISIÓN DE MERCADO PAGO
                total = (subtotal * 1.0422) + 4.84;
                const commission = total - subtotal;
                priceDisplay.innerText = `$${total.toFixed(2)} MN`;
                commDisplay.innerHTML = `Subtotal: $${subtotal.toFixed(2)} MN + Comisión portal: $${commission.toFixed(2)} MN`;
                commDisplay.style.display = 'block';
                
                // Actualizar input del copiador de Mercado Pago
                const mpInput = document.getElementById('mercadoPagoTotalInput');
                if (mpInput) {
                    mpInput.value = total.toFixed(2);
                }
            } else {
                priceDisplay.innerText = `$${total.toFixed(2)} MN`;
                commDisplay.style.display = 'none';
            }
        }

        // Inicializar el formulario con 1 participante
        renderParticipantForms();

        // --- 7. BOTÓN COPIAR INTELIGENTE ---
        function copyText(elementId, button) {
            const el = document.getElementById(elementId);
            const textToCopy = el.tagName === 'INPUT' ? el.value : el.innerText;
            navigator.clipboard.writeText(textToCopy).then(() => {
                const originalText = button.innerText;
                button.innerText = "¡Copiado! ✅";
                button.style.backgroundColor = "var(--carrera-rosa-medio)";
                setTimeout(() => {
                    button.innerText = originalText;
                    button.style.backgroundColor = "";
                }, 2000);
            }).catch(err => {
                console.error('Error al copiar texto: ', err);
            });
        }

        // --- 8. PROCESAR REGISTRO E INTEGRACIÓN CON WHATSAPP ---
        function processRegistration() {
            const count = parseInt(document.getElementById('num_participants').value);
            let runnerDetailsText = "";
            let participantsData = [];
            
            // Recopilar información de cada participante
            for (let i = 1; i <= count; i++) {
                const name = document.getElementById(`part_name_${i}`).value.trim();
                const age = document.getElementById(`part_age_${i}`).value.trim();
                const phone = document.getElementById(`part_phone_${i}`).value.trim();
                const modality = document.getElementById(`part_modality_${i}`).value;

                if (!name || !age || !phone) {
                    alert(`Por favor llena el nombre, edad y teléfono de la persona #${i}`);
                    return;
                }
                
                const shirtCheck = document.getElementById(`part_shirt_check_${i}`);
                const shirtSize = document.getElementById(`part_shirt_size_${i}`).value;

                // Recopilar datos estructurados para la Base de Datos (Google Sheets)
                participantsData.push({
                    nombre: name,
                    edad: age,
                    telefono: phone,
                    modalidad: modality,
                    camisa_extra: (shirtCheck && shirtCheck.checked) ? "SÍ" : "NO",
                    talla_camisa: (shirtCheck && shirtCheck.checked) ? shirtSize : "N/A"
                });

                runnerDetailsText += `🏃‍♀️ *Participante #${i}:*\n`;
                runnerDetailsText += `• Nombre: ${name}\n`;
                runnerDetailsText += `• Edad: ${age} años\n`;
                runnerDetailsText += `• Teléfono: ${phone}\n`;
                runnerDetailsText += `• Modalidad: ${modality}\n`;
                if (shirtCheck && shirtCheck.checked) {
                    runnerDetailsText += `• 👕 Camiseta Extra: SÍ (Talla: ${shirtSize})\n`;
                }
                runnerDetailsText += `\n`;
            }

            let subtotal = count * 200;
            for (let i = 1; i <= count; i++) {
                const check = document.getElementById(`part_shirt_check_${i}`);
                if (check && check.checked) {
                    subtotal += 250;
                }
            }
            let total = subtotal;
            let paymentMethodText = "";
            let additionalInstructions = "";

            if (currentPaymentMethod === 'transferencia') {
                paymentMethodText = "Transferencia Bancaria";
                additionalInstructions = "Adjunto el comprobante por este medio.";
            } else if (currentPaymentMethod === 'mercadopago') {
                paymentMethodText = "Pago Seguro en Línea (Mercado Pago)";
                total = (subtotal * 1.0422) + 4.84;
                const commission = total - subtotal;
                additionalInstructions = `Subtotal: $${subtotal.toFixed(2)} MN + Comisión: $${commission.toFixed(2)} MN.\nPor favor, envíenme el enlace de Mercado Pago para procesar.`;
            } else {
                paymentMethodText = "Efectivo en Consultorio";
                additionalInstructions = "Pasaré a liquidar y confirmar el registro directo en oficinas.";
            }

            // Construcción del mensaje final para la API de WhatsApp
            let message = `*🎗️ REGISTRO - 13VA. GRAN CARRERA CON CAUSA CELENE*\n\n`;
            message += `¡Hola Proyecto Celene Rosarito! 👋 Me interesa registrarme en la carrera.\n\n`;
            message += runnerDetailsText;
            message += `✅ He aceptado la exención de responsabilidad médica para participar en el evento.\n\n`;
            message += `*DATOS DE PAGO:*\n`;
            message += `• Método: ${paymentMethodText}\n`;
            message += `• Cantidad de boletos: ${count}\n`;
            message += `• *TOTAL A PAGAR: $${total.toFixed(2)} MN*\n\n`;
            message += `*Instrucciones:* ${additionalInstructions}`;

            const phoneNumber = "526611044050"; // Teléfono oficial
            const encodedText = encodeURIComponent(message);
            const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodedText}`;

            // --- LÓGICA DE GUARDADO EN BASE DE DATOS (GOOGLE SHEETS) ---
            const payload = {
                metodoPago: paymentMethodText,
                totalPago: total.toFixed(2),
                participants: participantsData
            };

            const submitBtn = document.querySelector('button[type="submit"]');
            const originalBtnText = submitBtn.innerHTML;
            submitBtn.innerHTML = "Guardando Registro... ⏳";
            submitBtn.disabled = true;

            // REEMPLAZA ESTE ENLACE POR LA URL DE TU APLICACIÓN WEB DE GOOGLE:
            const scriptURL = "https://script.google.com/macros/s/AKfycbxerpHfz9eNM3upzMq8Kz5uSxrm2R1fxGbECEoDB9QErJhedaRDIWp7Uewa8l2kxr5u/exec"; 

            fetch(scriptURL, {
                method: "POST",
                body: JSON.stringify(payload),
                headers: { "Content-Type": "text/plain;charset=utf-8" } // text/plain evita bloqueos de seguridad del navegador (CORS)
            })
            .then(response => {
                submitBtn.innerHTML = originalBtnText;
                submitBtn.disabled = false;
                window.open(whatsappUrl, '_blank'); // Abre WhatsApp cuando la base de datos confirma el guardado
            })
            .catch(error => {
                console.error("Error guardando en BD:", error);
                submitBtn.innerHTML = originalBtnText;
                submitBtn.disabled = false;
                window.open(whatsappUrl, '_blank'); // Abre WA como "Plan B" por si el internet de la persona falla
            });
        }
    </script>
    
    <!-- Script Global -->
    <script is:inline src="/js/global.js"></script>

