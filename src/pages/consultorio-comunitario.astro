---
// consultorio-comunitario.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Consultorio Comunitario - Proyecto Celene" description="El área médica de Proyecto Celene. Brindamos servicios de salud integral, consultas, laboratorios y prevención con cuotas accesibles.">
    <link rel="stylesheet" href="/css/global.css" />

        

        <header class="header">
            <img src="https://i.ibb.co/k2LCbnsF/tcarta-volante.png" alt="Logo Consultorio Comunitario Proyecto Celene"
                class="header-img">
            <p class="header-info">Bienvenido al corazón médico de Proyecto Celene. Aquí centralizamos todos nuestros
                esfuerzos de salud clínica, preventiva y tradicional para ofrecerte atención humana, profesional y a
                costos sumamente accesibles.</p>

            <div style="text-align: center; margin-top: 25px;">
                <a href="servicios.html" class="btn btn-rosa"
                    style="max-width: 400px; font-size: 1.2rem; padding: 15px;"><span>📋</span>
                    Conoce Todos Nuestros Servicios ➔</a>
            </div>
        </header>

        <section class="medical-grid">

            <div class="med-card">
                <img src="https://i.ibb.co/whkTFwLf/MAMOGRAFIA.jpg" alt="Mastografía Gratuita"
                    style="width: 100%; border-radius: 15px; border: 3px solid var(--pc-negro); margin-bottom: 15px; aspect-ratio: 1/1; object-fit: contain; background: white;">
                <h3 class="hand-drawn">🎀 Mastografía Gratuita</h3>
                <p>Estudios gratuitos para mujeres de 40 años o más (o 35 con antecedentes). Detección oportuna.</p>
                <a href="mastografia-gratuita.html" class="btn btn-rosa">Saber más ➔</a>
            </div>

            <div class="med-card">
                <img src="https://i.ibb.co/zhSRq5hX/CONSULTA-GENERAL.jpg" alt="Consulta General"
                    style="width: 100%; border-radius: 15px; border: 3px solid var(--pc-negro); margin-bottom: 15px; aspect-ratio: 1/1; object-fit: contain; background: white;">
                <h3 class="hand-drawn"><span>🩺</span> Consulta General</h3>
                <p>Atención profesional empática, tanto presencial como virtual, con una cuota de recuperación
                    accesible.</p>
                <a href="consulta-general.html" class="btn btn-azul">Saber más ➔</a>
            </div>

            <div class="med-card">
                <img src="https://i.ibb.co/Y7JyQgKp/CLINICA-VIRTUAL.jpg" alt="Orientación Médica Gratuita"
                    style="width: 100%; border-radius: 15px; border: 3px solid var(--pc-negro); margin-bottom: 15px; aspect-ratio: 1/1; object-fit: contain; background: white;">
                <h3 class="hand-drawn"><span>💬</span> Orientación Médica Gratuita</h3>
                <p>Resuelve dudas rápidas, recibe orientación profesional o agenda una teleconsulta sin salir de casa.
                </p>
                <a href="orientacion-medica-gratuita.html" class="btn btn-wa">Ir a Orientación ➔</a>
            </div>

            <div class="med-card">
                <img src="https://i.ibb.co/842xYCb3/SALUD-SEXUAL-ITS.jpg" alt="Clínica de Salud Sexual e ITS"
                    style="width: 100%; border-radius: 15px; border: 3px solid var(--pc-negro); margin-bottom: 15px; aspect-ratio: 1/1; object-fit: contain; background: white;">
                <h3 class="hand-drawn">🛡️ Clínica de Salud Sexual</h3>
                <p>Pruebas de VIH gratuitas, paquetes de detección de ITS y orientación en planificación familiar
                    confidencial.</p>
                <a href="salud-sexual.html" class="btn btn-amarillo">Saber más ➔</a>
            </div>

            <div class="med-card">
                <img src="https://i.ibb.co/Q7rXQMZd/EDUCACION.jpg" alt="Educación para Pacientes"
                    style="width: 100%; border-radius: 15px; border: 3px solid var(--pc-negro); margin-bottom: 15px; aspect-ratio: 1/1; object-fit: contain; background: white;">
                <h3 class="hand-drawn"><span>📖</span> Educación para Pacientes</h3>
                <p>Aprende a cuidar tu cuerpo. Encuentra manuales, infografías y herramientas de prevención integral.
                </p>
                <a href="recursos-educativos.html" class="btn btn-azul">Explorar Recursos ➔</a>
            </div>

            <div class="med-card">
                <img src="https://i.ibb.co/JjwF3cQm/FARMACIA-SOLIDARIA.jpg" alt="Farmacia Solidaria"
                    style="width: 100%; border-radius: 15px; border: 3px solid var(--pc-negro); margin-bottom: 15px; aspect-ratio: 1/1; object-fit: contain; background: white;">
                <h3 class="hand-drawn"><span>💊</span> Farmacia Solidaria</h3>
                <p>Un proyecto de apoyo mutuo para distribuir medicamentos a cuotas simbólicas para quienes más lo
                    necesitan.</p>
                <a href="farmacia-solidaria.html" class="btn btn-amarillo">Ir a la Farmacia ➔</a>
            </div>

            <!-- Nueva Clínica de Control de Peso -->
            <div class="med-card">
                <img src="https://i.ibb.co/BVbcyxJB/snoopy-control-de-peso.png"
                    alt="Clínica de Control de Peso"
                    style="width: 100%; border-radius: 15px; border: 3px solid var(--pc-negro); margin-bottom: 15px; aspect-ratio: 1/1; object-fit: cover; background: white;">
                <h3 class="hand-drawn"><span>⚖️</span> Control de Peso</h3>
                <p>Logra tu peso ideal de forma saludable, sin dietas extremas y con acompañamiento médico, clínico y
                    personalizado.</p>
                <a href="control-de-peso.html" class="btn btn-rosa">Saber más ➔</a>
            </div>
        </section>
    

    
</Layout>

<style is:global>
.container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 15px;
        }

.header {
            text-align: center;
            padding: 40px 20px;
            background: var(--pc-blanco);
            border: 4px solid var(--pc-negro);
            border-radius: 25px;
            margin-bottom: 40px;
            box-shadow: 8px 8px 0px var(--pc-azul-suave);
        }

.header-img {
            max-width: 100%;
            width: 450px;
            height: auto;
            margin: 0 auto 15px;
            display: block;
        }

.header-info {
            font-size: 1.15rem;
            max-width: 800px;
            margin: 0 auto;
            font-weight: 600;
            color: #444;
        }

.medical-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
        }

.med-card {
            background: white;
            border: 3px solid var(--pc-negro);
            border-radius: 20px;
            padding: 25px;
            text-align: center;
            transition: transform 0.2s;
            box-shadow: 6px 6px 0px var(--pc-rosa-pastell);
            display: flex;
            flex-direction: column;
        }

.med-card:hover {
            transform: translateY(-6px);
            box-shadow: 8px 8px 0px var(--pc-amarillo);
        }

.med-card h3 {
            color: var(--pc-negro);
            font-size: 1.6rem;
            margin-bottom: 15px;
        }

.med-card p {
            font-size: 1rem;
            color: #555;
            font-weight: 600;
            margin-bottom: 20px;
            flex-grow: 1;
        }

.btn-rosa {
            background: var(--pc-rosa-fuerte);
            color: white;
        }

.btn-azul {
            background: var(--pc-azul-suave);
            color: var(--pc-negro);
        }

.btn-amarillo {
            background: var(--pc-amarillo);
            color: var(--pc-negro);
        }

@media (max-width: 600px) {
            .header h1 {
                font-size: 2.2rem;
            }
        }
</style>
